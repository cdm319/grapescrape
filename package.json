{
  "name": "grapescrape",
  "version": "1.0.0",
  "description": "Scrape and alert to new wine additions at selected retailers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cdm319/grapescrape.git"
  },
  "license": "UNLICENSED",
  "private": true,
  "author": "Chris Matthews <chris@matthews.digital>",
  "type": "module",
  "workspaces": [
    "infra",
    "src/api",
    "src/domain",
    "src/state",
    "src/ui",
    "src/workers/retailer-scraper",
    "src/workers/wine-assessor"
  ],
  "scripts": {
    "cdk": "npm --workspace infra run cdk",
    "cdk:synth": "npm --workspace infra run synth",
    "cdk:diff": "npm --workspace infra run diff",
    "cdk:deploy": "npm --workspace infra run deploy",
    "test": "vitest run",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "vitest": "^4.1.10"
  }
}
